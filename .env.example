# === Proxy Server Configuration ===

# Port where the proxy listens
PORT=8080

# === Real IPTV Provider Credentials ===
# Update these when the provider changes credentials
PROVIDER_URL=http://tv.m3uts.xyz
PROVIDER_USERNAME=m
PROVIDER_PASSWORD=m

# === Proxy Authentication (what users enter in the app) ===
# Users will use these credentials to connect to YOUR proxy
PROXY_USERNAME=user
PROXY_PASSWORD=pass
